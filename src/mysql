-- =============================================================================
-- SECTION 2: USERS & AUTHENTICATION
-- =============================================================================

CREATE TABLE users (
    id                    UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    email                 VARCHAR(255) UNIQUE NOT NULL,
    phone_number          VARCHAR(15) UNIQUE,
    password_hash         VARCHAR(255),                          -- bcrypt cost 12; null for OAuth
    auth_provider         auth_provider_enum NOT NULL DEFAULT 'local',
    provider_uid          VARCHAR(200),                          -- OAuth sub/uid
    account_status        account_status_enum NOT NULL DEFAULT 'pending_verify',
    email_verified        BOOLEAN NOT NULL DEFAULT FALSE,
    phone_verified        BOOLEAN NOT NULL DEFAULT FALSE,
    email_verify_token    VARCHAR(100),                          -- stored as hash
    email_verify_expires  TIMESTAMPTZ,
    password_reset_token  VARCHAR(100),                          -- stored as hash, single-use
    password_reset_expires TIMESTAMPTZ,
    failed_login_count    SMALLINT NOT NULL DEFAULT 0,
    locked_until          TIMESTAMPTZ,
    last_login_at         TIMESTAMPTZ,
    last_login_ip         INET,
    created_at            TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    deleted_at            TIMESTAMPTZ                            -- soft delete
);

CREATE INDEX idx_users_email ON users (LOWER(email));
CREATE INDEX idx_users_phone ON users (phone_number) WHERE phone_number IS NOT NULL;
CREATE INDEX idx_users_status ON users (account_status);
CREATE INDEX idx_users_deleted ON users (deleted_at) WHERE deleted_at IS NULL;


CREATE TABLE user_sessions (
    id                  UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id             UUID NOT NULL REFERENCES users (id) ON DELETE CASCADE,
    token_hash          VARCHAR(255) NOT NULL,                   -- SHA-256 of JWT
    device_fingerprint  VARCHAR(200),
    device_type         device_type_enum NOT NULL DEFAULT 'unknown',
    ip_address          INET,
    user_agent          TEXT,
    location_country    CHAR(2),
    is_active           BOOLEAN NOT NULL DEFAULT TRUE,
    expires_at          TIMESTAMPTZ NOT NULL,
    created_at          TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    revoked_at          TIMESTAMPTZ
);

CREATE INDEX idx_sessions_user ON user_sessions (user_id);
CREATE INDEX idx_sessions_token ON user_sessions (token_hash) WHERE is_active = TRUE;
CREATE INDEX idx_sessions_active ON user_sessions (user_id, is_active) WHERE is_active = TRUE;


CREATE TABLE user_mfa (
    id           UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id      UUID NOT NULL UNIQUE REFERENCES users (id) ON DELETE CASCADE,
    mfa_type     mfa_type_enum NOT NULL DEFAULT 'sms_otp',
    totp_secret  VARCHAR(100),                                   -- AES-256 encrypted at app layer
    is_enabled   BOOLEAN NOT NULL DEFAULT FALSE,
    backup_codes JSONB,                                          -- array of hashed codes
    verified_at  TIMESTAMPTZ
);


CREATE TABLE security_audit_log (
    id           BIGSERIAL PRIMARY KEY,                          -- sequential = tamper-evident
    user_id      UUID REFERENCES users (id) ON DELETE SET NULL,  -- nullable: pre-auth events
    event_type   audit_event_enum NOT NULL,
    ip_address   INET,
    user_agent   TEXT,
    metadata     JSONB,
    performed_by UUID REFERENCES users (id) ON DELETE SET NULL,  -- admin acting on behalf
    created_at   TIMESTAMPTZ NOT NULL DEFAULT NOW()
    -- NEVER delete rows from this table
);

CREATE INDEX idx_audit_user ON security_audit_log (user_id);
CREATE INDEX idx_audit_event ON security_audit_log (event_type);
CREATE INDEX idx_audit_created ON security_audit_log (created_at DESC);


