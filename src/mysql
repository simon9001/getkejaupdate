-- ─────────────────────────────────────────────────────────────────────────────
-- SECTION 5: ANTI-FRAUD REVIEW SYSTEM
--
-- Design principles:
--   1. Verified interaction requirement — reviewer MUST have a linked booking
--      or completed visit (no anonymous reviews, no "walk-in" reviews)
--   2. Review holds — new reviews enter 'pending' and are auto-published after
--      24h unless a fraud signal fires during that window
--   3. Fraud signals — computed at submission time and stored; any HIGH-confidence
--      signal sends the review to 'held_for_moderation' instead of 'pending'
--   4. One review per verified interaction — enforced by UNIQUE on
--      (reviewer_id, interaction_id) where interaction_id is the booking/visit
--   5. Cooling-off period — 48h after checkout/visit before review allowed
--      (prevents rage-reviews, gives time for reflection)
--   6. Mutual review blind — both parties submit independently; neither sees
--      the other's review until both have submitted OR the 14-day window closes
--   7. Edit window — reviewer can edit within 48h of submission
--   8. Platform fee: 0 — reviews are never gated behind payment to prevent bias
-- ─────────────────────────────────────────────────────────────────────────────

CREATE TYPE unified_review_status_enum AS ENUM (
    'pending',                 -- submitted, within 24h auto-publish window
    'published',               -- visible to all
    'held_for_moderation',     -- fraud signal fired, awaiting admin review
    'blind_pending',           -- waiting for both parties to submit (mutual blind)
    'rejected',                -- admin rejected after review
    'removed_violation'        -- removed post-publication for policy violation
);

CREATE TABLE unified_reviews (
    id                      UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    review_type             tenancy_review_type_enum NOT NULL,

    -- Who is reviewing whom / what
    reviewer_id             UUID NOT NULL REFERENCES users (id) ON DELETE CASCADE,
    reviewee_id             UUID REFERENCES users (id) ON DELETE CASCADE,   -- null for property reviews
    property_id             UUID REFERENCES properties (id) ON DELETE CASCADE,

    -- VERIFIED INTERACTION REQUIREMENT
    -- Exactly ONE of these must be non-null — enforced by CHECK below
    visit_id                UUID REFERENCES visit_schedules (id) ON DELETE RESTRICT,
    long_term_booking_id    UUID REFERENCES long_term_bookings (id) ON DELETE RESTRICT,
    short_stay_booking_id   UUID REFERENCES short_stay_bookings (id) ON DELETE RESTRICT,

    -- Ratings (1–5)
    rating_overall          SMALLINT NOT NULL CHECK (rating_overall BETWEEN 1 AND 5),
    rating_cleanliness      SMALLINT CHECK (rating_cleanliness BETWEEN 1 AND 5),
    rating_communication    SMALLINT CHECK (rating_communication BETWEEN 1 AND 5),
    rating_accuracy         SMALLINT CHECK (rating_accuracy BETWEEN 1 AND 5),
    rating_value            SMALLINT CHECK (rating_value BETWEEN 1 AND 5),
    rating_location         SMALLINT CHECK (rating_location BETWEEN 1 AND 5),
    -- Landlord/tenant specific
    rating_maintenance      SMALLINT CHECK (rating_maintenance BETWEEN 1 AND 5),
    rating_responsiveness   SMALLINT CHECK (rating_responsiveness BETWEEN 1 AND 5),
    rating_house_rules      SMALLINT CHECK (rating_house_rules BETWEEN 1 AND 5),

    review_text             TEXT CHECK (
                                -- Require text for extreme ratings to reduce noise
                                rating_overall BETWEEN 2 AND 4
                                OR (review_text IS NOT NULL AND LENGTH(review_text) >= 20)
                            ),

    -- Public reply from reviewee
    reply_text              TEXT,
    replied_at              TIMESTAMPTZ,

    -- Status & moderation
    status                  unified_review_status_enum NOT NULL DEFAULT 'pending',
    auto_publish_at         TIMESTAMPTZ,    -- 24h after submission if no fraud signal
    published_at            TIMESTAMPTZ,
    moderated_by            UUID REFERENCES users (id) ON DELETE SET NULL,
    moderation_notes        TEXT,

    -- Mutual blind tracking (for landlord↔tenant pairs)
    blind_pair_review_id    UUID REFERENCES unified_reviews (id) ON DELETE SET NULL,
    both_submitted          BOOLEAN NOT NULL DEFAULT FALSE,

    -- Edit window (48h from submission)
    last_edited_at          TIMESTAMPTZ,
    edit_count              SMALLINT NOT NULL DEFAULT 0,

    -- Submission metadata for fraud detection
    submitted_ip            INET,
    submitted_user_agent    TEXT,
    account_age_days_at_submission  INTEGER,  -- computed at insert
    reviewer_total_reviews_at_submission INTEGER,

    submitted_at            TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    -- ── Constraints ──────────────────────────────────────────────────────
    -- Exactly one interaction source
    CONSTRAINT chk_one_interaction CHECK (
        (CASE WHEN visit_id IS NOT NULL THEN 1 ELSE 0 END
         + CASE WHEN long_term_booking_id IS NOT NULL THEN 1 ELSE 0 END
         + CASE WHEN short_stay_booking_id IS NOT NULL THEN 1 ELSE 0 END) = 1
    ),
    -- One review per reviewer per interaction source
    CONSTRAINT uq_review_per_visit         UNIQUE (reviewer_id, visit_id),
    CONSTRAINT uq_review_per_lt_booking    UNIQUE (reviewer_id, long_term_booking_id),
    CONSTRAINT uq_review_per_st_booking    UNIQUE (reviewer_id, short_stay_booking_id)
);

CREATE INDEX idx_reviews_property    ON unified_reviews (property_id)  WHERE status = 'published';
CREATE INDEX idx_reviews_reviewee    ON unified_reviews (reviewee_id)  WHERE status = 'published';
CREATE INDEX idx_reviews_reviewer    ON unified_reviews (reviewer_id);
CREATE INDEX idx_reviews_status      ON unified_reviews (status);
CREATE INDEX idx_reviews_auto_pub    ON unified_reviews (auto_publish_at) WHERE status = 'pending';


-- Fraud signals table — one row per signal per review
CREATE TABLE review_fraud_signals (
    id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    review_id   UUID NOT NULL REFERENCES unified_reviews (id) ON DELETE CASCADE,
    signal      fraud_signal_enum NOT NULL,
    confidence  VARCHAR(10) NOT NULL CHECK (confidence IN ('low','medium','high')),
    detail      TEXT,
    detected_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    resolved    BOOLEAN NOT NULL DEFAULT FALSE,
    resolved_by UUID REFERENCES users (id) ON DELETE SET NULL,
    resolved_at TIMESTAMPTZ
);

CREATE INDEX idx_fraud_signals_review   ON review_fraud_signals (review_id);
CREATE INDEX idx_fraud_signals_unresolved ON review_fraud_signals (resolved) WHERE resolved = FALSE;


-- Review aggregate (materialised, updated by trigger — one row per property)
CREATE TABLE review_aggregates (
    property_id           UUID PRIMARY KEY REFERENCES properties (id) ON DELETE CASCADE,
    total_reviews         INTEGER NOT NULL DEFAULT 0,
    avg_overall           DECIMAL(3,2),
    avg_cleanliness       DECIMAL(3,2),
    avg_communication     DECIMAL(3,2),
    avg_accuracy          DECIMAL(3,2),
    avg_value             DECIMAL(3,2),
    avg_location          DECIMAL(3,2),
    avg_maintenance       DECIMAL(3,2),
    avg_responsiveness    DECIMAL(3,2),
    pct_five_star         DECIMAL(5,2),
    pct_one_star          DECIMAL(5,2),
    last_updated          TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE OR REPLACE FUNCTION refresh_review_aggregates()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
    IF NEW.property_id IS NULL THEN RETURN NEW; END IF;

    INSERT INTO review_aggregates (
        property_id, total_reviews,
        avg_overall, avg_cleanliness, avg_communication,
        avg_accuracy, avg_value, avg_location,
        avg_maintenance, avg_responsiveness,
        pct_five_star, pct_one_star, last_updated
    )
    SELECT
        NEW.property_id,
        COUNT(*),
        ROUND(AVG(rating_overall)::NUMERIC, 2),
        ROUND(AVG(rating_cleanliness)::NUMERIC, 2),
        ROUND(AVG(rating_communication)::NUMERIC, 2),
        ROUND(AVG(rating_accuracy)::NUMERIC, 2),
        ROUND(AVG(rating_value)::NUMERIC, 2),
        ROUND(AVG(rating_location)::NUMERIC, 2),
        ROUND(AVG(rating_maintenance)::NUMERIC, 2),
        ROUND(AVG(rating_responsiveness)::NUMERIC, 2),
        ROUND(100.0 * COUNT(*) FILTER (WHERE rating_overall = 5) / NULLIF(COUNT(*), 0), 2),
        ROUND(100.0 * COUNT(*) FILTER (WHERE rating_overall = 1) / NULLIF(COUNT(*), 0), 2),
        NOW()
    FROM unified_reviews
    WHERE property_id = NEW.property_id AND status = 'published'
    ON CONFLICT (property_id) DO UPDATE SET
        total_reviews      = EXCLUDED.total_reviews,
        avg_overall        = EXCLUDED.avg_overall,
        avg_cleanliness    = EXCLUDED.avg_cleanliness,
        avg_communication  = EXCLUDED.avg_communication,
        avg_accuracy       = EXCLUDED.avg_accuracy,
        avg_value          = EXCLUDED.avg_value,
        avg_location       = EXCLUDED.avg_location,
        avg_maintenance    = EXCLUDED.avg_maintenance,
        avg_responsiveness = EXCLUDED.avg_responsiveness,
        pct_five_star      = EXCLUDED.pct_five_star,
        pct_one_star       = EXCLUDED.pct_one_star,
        last_updated       = NOW();
    RETURN NEW;
END;
$$;

