-- Auto-populate property_search_index when a property is published
CREATE OR REPLACE FUNCTION sync_property_search_index()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
DECLARE
    v_loc   property_locations%ROWTYPE;
    v_price property_pricing%ROWTYPE;
    v_score listing_search_scores%ROWTYPE;
BEGIN
    SELECT * INTO v_loc   FROM property_locations WHERE property_id = NEW.id;
    SELECT * INTO v_price FROM property_pricing   WHERE property_id = NEW.id;
    SELECT * INTO v_score FROM listing_search_scores WHERE property_id = NEW.id;

    INSERT INTO property_search_index (
        property_id, listing_category, listing_type, bedrooms, bathrooms,
        monthly_rent_kes, asking_price_kes, county, area, geom,
        is_furnished, has_parking, has_borehole, is_gated,
        visibility_score, status, full_text_vector, last_synced
    ) VALUES (
        NEW.id,
        NEW.listing_category::TEXT,
        NEW.listing_type::TEXT,
        NEW.bedrooms,
        NEW.bathrooms,
        v_price.monthly_rent,
        v_price.asking_price,
        v_loc.county,
        v_loc.area,
        v_loc.geom,
        NEW.is_furnished::TEXT,
        CASE WHEN NEW.parking_spaces > 0 THEN TRUE ELSE FALSE END,
        NEW.has_borehole,
        NEW.compound_is_gated,
        COALESCE(v_score.total_score, 0),
        NEW.status::TEXT,
        to_tsvector('english',
            COALESCE(NEW.title, '') || ' ' ||
            COALESCE(NEW.description, '') || ' ' ||
            COALESCE(v_loc.county, '') || ' ' ||
            COALESCE(v_loc.area, '') || ' ' ||
            COALESCE(v_loc.estate_name, '') || ' ' ||
            COALESCE(v_loc.nearest_landmark, '')
        ),
        NOW()
    )
    ON CONFLICT (property_id) DO UPDATE SET
        listing_category  = EXCLUDED.listing_category,
        listing_type      = EXCLUDED.listing_type,
        bedrooms          = EXCLUDED.bedrooms,
        bathrooms         = EXCLUDED.bathrooms,
        monthly_rent_kes  = EXCLUDED.monthly_rent_kes,
        asking_price_kes  = EXCLUDED.asking_price_kes,
        county            = EXCLUDED.county,
        area              = EXCLUDED.area,
        geom              = EXCLUDED.geom,
        is_furnished      = EXCLUDED.is_furnished,
        has_parking       = EXCLUDED.has_parking,
        has_borehole      = EXCLUDED.has_borehole,
        is_gated          = EXCLUDED.is_gated,
        visibility_score  = EXCLUDED.visibility_score,
        status            = EXCLUDED.status,
        full_text_vector  = EXCLUDED.full_text_vector,
        last_synced       = NOW();

    RETURN NEW;
END;
$$;

CREATE TRIGGER trg_sync_search_index
    AFTER INSERT OR UPDATE OF status, bedrooms, bathrooms, is_furnished,
        parking_spaces, has_borehole, compound_is_gated, title, description
    ON properties
    FOR EACH ROW EXECUTE FUNCTION sync_property_search_index();


-- Auto-deactivate expired boosts
CREATE OR REPLACE FUNCTION deactivate_expired_boosts()
RETURNS VOID LANGUAGE plpgsql AS $$
BEGIN
    UPDATE listing_boosts
    SET is_active = FALSE
    WHERE is_active = TRUE AND ends_at < NOW();

    -- Recompute boost_score for affected properties
    UPDATE listing_search_scores lss
    SET boost_score = COALESCE((
        SELECT SUM(bp.visibility_score_bonus)
        FROM listing_boosts lb
        JOIN boost_packages bp ON lb.package_id = bp.id
        WHERE lb.property_id = lss.property_id AND lb.is_active = TRUE
    ), 0),
    last_recalculated = NOW();
END;
$$;
-- Schedule via pg_cron: SELECT cron.schedule('0 * * * *', 'SELECT deactivate_expired_boosts()');


-- Smart search helper: find properties near a landmark within budget
CREATE OR REPLACE FUNCTION search_properties_near_landmark(
    p_landmark_lat      DECIMAL,
    p_landmark_lng      DECIMAL,
    p_radius_km         DECIMAL DEFAULT 3,
    p_bedrooms          SMALLINT DEFAULT NULL,
    p_budget_min        DECIMAL DEFAULT NULL,
    p_budget_max        DECIMAL DEFAULT NULL,
    p_listing_category  VARCHAR DEFAULT NULL,
    p_limit             INTEGER DEFAULT 20
)
RETURNS TABLE (
    property_id      UUID,
    listing_category VARCHAR,
    listing_type     VARCHAR,
    bedrooms         SMALLINT,
    monthly_rent_kes DECIMAL,
    asking_price_kes DECIMAL,
    county           VARCHAR,
    area             VARCHAR,
    distance_m       DOUBLE PRECISION,
    visibility_score INTEGER
)
LANGUAGE plpgsql AS $$
BEGIN
    RETURN QUERY
    SELECT
        psi.property_id,
        psi.listing_category,
        psi.listing_type,
        psi.bedrooms,
        psi.monthly_rent_kes,
        psi.asking_price_kes,
        psi.county,
        psi.area,
        ST_Distance(
            psi.geom::GEOGRAPHY,
            ST_SetSRID(ST_MakePoint(p_landmark_lng, p_landmark_lat), 4326)::GEOGRAPHY
        ) AS distance_m,
        psi.visibility_score
    FROM property_search_index psi
    WHERE
        psi.status = 'available'
        AND ST_DWithin(
            psi.geom::GEOGRAPHY,
            ST_SetSRID(ST_MakePoint(p_landmark_lng, p_landmark_lat), 4326)::GEOGRAPHY,
            p_radius_km * 1000
        )
        AND (p_bedrooms IS NULL OR psi.bedrooms = p_bedrooms)
        AND (p_listing_category IS NULL OR psi.listing_category = p_listing_category)
        AND (p_budget_min IS NULL OR
             COALESCE(psi.monthly_rent_kes, psi.asking_price_kes) >= p_budget_min)
        AND (p_budget_max IS NULL OR
             COALESCE(psi.monthly_rent_kes, psi.asking_price_kes) <= p_budget_max)
    ORDER BY psi.visibility_score DESC, distance_m ASC
    LIMIT p_limit;
END;
$$;


