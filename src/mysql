    rating_accuracy      SMALLINT     CHECK (rating_accuracy BETWEEN 1 AND 5),
    rating_communication SMALLINT     CHECK (rating_communication BETWEEN 1 AND 5),
    rating_location      SMALLINT     CHECK (rating_location BETWEEN 1 AND 5),
