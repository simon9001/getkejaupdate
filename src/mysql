-- ─────────────────────────────────────────────────────────────────────────────
-- PROPERTY REVIEW AGGREGATE — materialised summary updated by trigger
-- Keeps average ratings on the property without expensive aggregates on reads
-- ─────────────────────────────────────────────────────────────────────────────
CREATE TABLE property_review_stats (
    property_id          UUID PRIMARY KEY REFERENCES properties (id) ON DELETE CASCADE,
    total_reviews        INTEGER NOT NULL DEFAULT 0,
    avg_overall          DECIMAL(3,2),
    avg_cleanliness      DECIMAL(3,2),
    avg_accuracy         DECIMAL(3,2),
    avg_communication    DECIMAL(3,2),
    avg_location         DECIMAL(3,2),
    avg_value            DECIMAL(3,2),
    last_updated         TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

-- Trigger to refresh review stats when a review is published
CREATE OR REPLACE FUNCTION refresh_property_review_stats()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
    INSERT INTO property_review_stats (
        property_id, total_reviews,
        avg_overall, avg_cleanliness, avg_accuracy,
        avg_communication, avg_location, avg_value, last_updated
    )
    SELECT
        NEW.property_id,
        COUNT(*),
        ROUND(AVG(rating_overall)::NUMERIC, 2),
        ROUND(AVG(rating_cleanliness)::NUMERIC, 2),
        ROUND(AVG(rating_accuracy)::NUMERIC, 2),
        ROUND(AVG(rating_communication)::NUMERIC, 2),
        ROUND(AVG(rating_location)::NUMERIC, 2),
        ROUND(AVG(rating_value)::NUMERIC, 2),
        NOW()
    FROM property_reviews
    WHERE property_id = NEW.property_id AND status = 'published'
    ON CONFLICT (property_id) DO UPDATE SET
        total_reviews     = EXCLUDED.total_reviews,
        avg_overall       = EXCLUDED.avg_overall,
        avg_cleanliness   = EXCLUDED.avg_cleanliness,
        avg_accuracy      = EXCLUDED.avg_accuracy,
        avg_communication = EXCLUDED.avg_communication,
        avg_location      = EXCLUDED.avg_location,
        avg_value         = EXCLUDED.avg_value,
        last_updated      = NOW();
    RETURN NEW;
END;
$$;

CREATE TRIGGER trg_refresh_review_stats
    AFTER INSERT OR UPDATE OF status ON property_reviews
    FOR EACH ROW
    WHEN (NEW.status = 'published')
    EXECUTE FUNCTION refresh_property_review_stats();





