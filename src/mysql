    'velocity_multiple_reviews',    -- same user reviewing many properties fast
    'ip_cluster',                   -- multiple reviews from same IP range
    'account_age_too_new',          -- account < 7 days old at time of review
    'no_verified_interaction',      -- reviewer never had a booking/visit
    'text_duplicate',               -- review text matches another review ≥ 80%
    'rating_extreme_no_text',       -- 1 or 5 stars with no review text
    'reciprocal_pattern'            -- mutual 5-star swap between two accounts
);

-- ─────────────────────────────────────────────────────────────────────────────
-- SECTION 2: CHAT SYSTEM
-- ─────────────────────────────────────────────────────────────────────────────

-- A conversation is always tied to a property and has exactly 2 participants
-- (seeker + host/agent/caretaker). Support conversations may have an admin.
CREATE TABLE conversations (
    id                UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    property_id       UUID REFERENCES properties (id) ON DELETE SET NULL,
    type              conversation_type_enum NOT NULL DEFAULT 'property_enquiry',

    -- Participants — denormalised for fast lookup
    participant_a     UUID NOT NULL REFERENCES users (id) ON DELETE CASCADE,  -- seeker
    participant_b     UUID NOT NULL REFERENCES users (id) ON DELETE CASCADE,  -- host/agent/admin

    -- Last message cache (avoids JOIN on list view)
    last_message_at   TIMESTAMPTZ,
    last_message_text VARCHAR(200),          -- truncated preview

    -- Unread counts per participant
    unread_a          SMALLINT NOT NULL DEFAULT 0,
    unread_b          SMALLINT NOT NULL DEFAULT 0,

    -- Soft-archiving (hide from inbox without deleting)
    archived_by_a     BOOLEAN NOT NULL DEFAULT FALSE,
    archived_by_b     BOOLEAN NOT NULL DEFAULT FALSE,

    is_blocked        BOOLEAN NOT NULL DEFAULT FALSE,
    blocked_by        UUID REFERENCES users (id) ON DELETE SET NULL,

    created_at        TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    updated_at        TIMESTAMPTZ NOT NULL DEFAULT NOW(),

    -- Prevent duplicate conversations for the same property+pair
    CONSTRAINT uq_conversation UNIQUE (property_id, participant_a, participant_b)
);

CREATE INDEX idx_conv_participant_a  ON conversations (participant_a, last_message_at DESC);
CREATE INDEX idx_conv_participant_b  ON conversations (participant_b, last_message_at DESC);
CREATE INDEX idx_conv_property       ON conversations (property_id);
CREATE INDEX idx_conv_updated        ON conversations (updated_at DESC);


CREATE TABLE messages (
    id               UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    conversation_id  UUID NOT NULL REFERENCES conversations (id) ON DELETE CASCADE,
    sender_id        UUID NOT NULL REFERENCES users (id) ON DELETE CASCADE,
    type             message_type_enum NOT NULL DEFAULT 'text',

    -- Content
    body             TEXT,                    -- text content or JSON payload for cards
    media_url        TEXT,                    -- Cloudinary URL for image/document
    media_mime_type  VARCHAR(100),
    media_filename   VARCHAR(200),

    -- Read receipts
    read_by_recipient BOOLEAN NOT NULL DEFAULT FALSE,
    read_at           TIMESTAMPTZ,

    -- Edit / delete
    is_deleted        BOOLEAN NOT NULL DEFAULT FALSE,
    deleted_at        TIMESTAMPTZ,
    edited_at         TIMESTAMPTZ,

    -- Thread reference (reply-to)
    reply_to_id       UUID REFERENCES messages (id) ON DELETE SET NULL,

    -- Metadata for card messages (visit_request, booking_offer)
    metadata          JSONB,

    created_at        TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX idx_messages_conv    ON messages (conversation_id, created_at DESC);
CREATE INDEX idx_messages_sender  ON messages (sender_id);
CREATE INDEX idx_messages_unread  ON messages (conversation_id, read_by_recipient)
    WHERE read_by_recipient = FALSE AND is_deleted = FALSE;

-- Trigger: update conversations.last_message_at on every new message
CREATE OR REPLACE FUNCTION update_conversation_on_message()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN
    UPDATE conversations
    SET
        last_message_at   = NEW.created_at,
        last_message_text = LEFT(COALESCE(NEW.body, ''), 200),
        updated_at        = NOW(),
        -- Increment unread for the recipient
        unread_a = CASE
            WHEN participant_b = NEW.sender_id THEN unread_a + 1
            ELSE unread_a END,
        unread_b = CASE
            WHEN participant_a = NEW.sender_id THEN unread_b + 1
            ELSE unread_b END
    WHERE id = NEW.conversation_id;
    RETURN NEW;
END;
$$;

CREATE TRIGGER trg_message_updates_conversation
    AFTER INSERT ON messages
    FOR EACH ROW EXECUTE FUNCTION update_conversation_on_message();


