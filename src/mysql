    nights               SMALLINT GENERATED ALWAYS AS
                             (check_out_date - check_in_date) STORED,
    guests_count         SMALLINT NOT NULL DEFAULT 1,

    -- Pricing snapshot (captured at booking time — prices may change later)
    price_per_night_kes  DECIMAL(10,2) NOT NULL,
