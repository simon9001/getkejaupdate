-- GETKEJA — Short-Stay (Airbnb-Style) Migration
-- Run this after the main schema migration.
-- New tables:
--   short_stay_bookings     — the core booking record
--   booking_payments        — payment ledger (guest charge + owner payout)
--   booking_checkins        — check-in / check-out events (escrow release trigger)
--   booking_cancellations   — cancellation audit with refund calculation
