-- ─────────────────────────────────────────────────────────────────────────────
-- ENUMS
-- ─────────────────────────────────────────────────────────────────────────────

CREATE TYPE booking_status_enum AS ENUM (
    'pending_payment',    -- created, awaiting guest payment
    'confirmed',          -- payment received, host notified
    'checked_in',         -- guest confirmed check-in (escrow released to host)
    'checked_out',        -- stay complete
    'cancelled_guest',    -- cancelled by guest (refund per policy)
    'cancelled_host',     -- cancelled by host (full refund)
    'disputed',           -- under dispute review
    'completed'           -- review window closed, fully settled
);

CREATE TYPE payment_role_enum AS ENUM (
    'guest_charge',       -- payment from guest → platform escrow
    'host_payout',        -- release from escrow → host (after check-in)
    'platform_fee',       -- platform commission retained
    'refund_guest',       -- refund from escrow → guest (on cancellation)
    'penalty_host'        -- host penalty for late cancellation
);

CREATE TYPE payment_ledger_status_enum AS ENUM (
    'pending',            -- payment initiated
    'held_escrow',        -- funds in escrow (confirmed booking)
    'released',           -- funds transferred to recipient
    'failed',             -- payment/payout failed
    'refunded'            -- refunded to source
);

CREATE TYPE checkin_type_enum AS ENUM (
    'guest_self',         -- guest self-checked in via app
    'host_confirmed',     -- host confirmed guest arrived
    'admin_override'      -- admin override (dispute resolution)
);

CREATE TYPE cancellation_policy_enum AS ENUM (
    'flexible',           -- full refund up to 24h before check-in
    'moderate',           -- full refund up to 5 days before check-in
    'strict',             -- 50% refund up to 7 days before check-in
    'non_refundable'      -- no refund
);

CREATE TYPE review_status_enum AS ENUM (
    'pending',            -- within review window (14 days post checkout)
    'published',          -- visible to all
    'flagged',            -- flagged for review by admin
    'removed'             -- removed by admin
);

CREATE TYPE dispute_status_enum AS ENUM (
    'open',
    'under_review',
    'resolved_guest',
    'resolved_host',
    'escalated'
);

