# ─── Server ───────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_very_long_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=15m

# ─── Email / SMTP ─────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
SMTP_FROM_EMAIL=no-reply@getkeja.online
SMTP_FROM_NAME=Getkeja

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5174

# ─── Cloudinary (image storage) ───────────────────────────────
# Cloud name and API key are already set in the service.
# You MUST add your API secret here — never expose it to the frontend.
CLOUDINARY_CLOUD_NAME=dwuizf438
CLOUDINARY_API_KEY=882356767525192
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
